<?xml version="1.0" encoding="UTF-8"?>
<configuration  scan="true" scanPeriod="30 seconds">
    <include resource="org/springframework/boot/logging/logback/defaults.xml"/>
    <jmxConfigurator/>
    <springProfile name="local,dev">
        <appender name="console" class="ch.qos.logback.core.ConsoleAppender">
            <encoder>
                <pattern>%blue(%d{yyyy-MM-dd HH:mm:ss.SSS}) %highlight([%level])  %magenta([%thread]) %cyan(%logger.%M\(%F:%L\)) - %msg%n</pattern>
            </encoder>
        </appender>
        <root level="INFO">
            <appender-ref ref="console"/>
        </root>
        <!-- 禁用Nacos默认Appender -->
        <logger name="com.alibaba.nacos" level="INFO" additivity="false">
            <appender-ref ref="console"/> <!-- 替换为你的Appender -->
        </logger>
        <logger name="com.intransit.schedule.mapper" level="DEBUG"/>
        <logger name="com.alibaba.cloud.nacos" level="DEBUG"/>
        <logger name="org.springframework.cloud.bootstrap" level="DEBUG"/>
        <logger name="org.flowable" level="debug"/>
    </springProfile>

    <springProfile name="test,online,uat">
        <property name="log.dir" value="${log.path}"/>
        <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
            <file>${log.dir}/stdout.log</file>
            <encoder class="ch.qos.logback.classic.encoder.PatternLayoutEncoder">
                <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%level] [%thread] %logger.%M\(%F:%L\) - %msg%n</pattern>
            </encoder>

            <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
                <FileNamePattern>${log.dir}/otherdays/stdout.%d{yyyy-MM-dd}.log</FileNamePattern>
                <MaxHistory>7</MaxHistory>
            </rollingPolicy>
        </appender>

        <appender name="FILE_ERROR" class="ch.qos.logback.core.rolling.RollingFileAppender">
            <file>${log.dir}/stderr.log</file>
            <encoder class="ch.qos.logback.classic.encoder.PatternLayoutEncoder">
                <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%level] [%thread] %logger.%M\(%F:%L\) - %msg%n</pattern>
            </encoder>

            <filter class="ch.qos.logback.classic.filter.ThresholdFilter">
                <level>WARN</level>
            </filter>

            <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
                <FileNamePattern>${log.dir}/otherdays/stderr.%d{yyyy-MM-dd}.log</FileNamePattern>
                <MaxHistory>7</MaxHistory>
            </rollingPolicy>
        </appender>

        <root level="INFO">
            <appender-ref ref="FILE"/>
            <appender-ref ref="FILE_ERROR"/>
<!--            <appender-ref ref="HddLogbackErrorAppender"/>-->
        </root>
        <logger name="com.xxl.job.core" level="INFO"/>
        <logger name="org.flowable" level="INFO"/>
    </springProfile>

</configuration>
